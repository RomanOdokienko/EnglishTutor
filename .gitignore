# Python bytecode cache
__pycache__/
*.pyc

# Secrets — never commit. The token doc holds the live OpenAI/AssemblyAI keys.
*.docx
.env
.env.*

# Skill tooling (installed via `npx skills add`) — not part of the app.
.agents/
.claude/skills/
skills-lock.json

# Recorded audio. Kept locally on purpose (it is the only input that cannot be
# re-derived — see cli.py --import-audio), but far too large for git.
sessions/*/audio.*
english-tutor-*.webm
english-tutor-*.ogg
